    <script>
        if (window.self === window.top) {
            window.location.replace("/?path=" + window.location.pathname);
        }
    </script>
    <script>
        document.addEventListener("click", e => {
            const link = e.target.closest("a");
            if (!link) return;

            const audio = new Audio("../audio/click.wav");
            audio.volume = 0.1;
            audio.play();

            e.preventDefault();
            document.getElementById("schmove").classList.add("fade-out");
            document.getElementsByClassName("icon")[0].classList.add("fade-out");
            setTimeout(() => {
                window.location = link.href;
                }, 2000);
            });
            window.addEventListener("pageshow", event => {
            document.getElementById("schmove").classList.remove("fade-out");
            document.getElementsByClassName("icon")[0].classList.remove("fade-out");
        });
    </script>
    <script>
        displayItemDescription = "";
        const description = document.getElementById("descriptions");
        let dindex = 0;

        async function animateDescription() {
            if (displayItemDescription != description.innerHTML){
                description.style.height = "30%";
                description.style.padding = "1%";
                description.style.outline = "2px var(--quoteOutline) solid";
                for (let i = 0; i < 2; i++) {
                    description.innerHTML = `${displayItemDescription.substring(0, dindex)}${random.charAt(Math.floor(Math.random() * random.length))}`;
                    await sleep(10);
                    dindex += 1;
                }
            } else {
                dindex = 0;
            }
            if (dindex < displayItemDescription.length) {
                setTimeout(animateDescription, 5);
            } else {
                description.innerHTML = displayItemDescription;
                setTimeout(animateDescription, 500);
            }
        }

        _ = animateDescription();
    </script>
    <script>
        const title = document.getElementById("title");
        let titleText = "Hello, World!";
        let random = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@@#$%^&*()_+-=[]{}|;':,.<>/?`~";
        let index = 0;

        function sleep(ms) {
            return new Promise(resolve => setTimeout(resolve, ms));
        }

        async function animateTitle() {
            for (let i = 0; i < 2; i++) {
                title.textContent = `${titleText.substring(0, index)}${random.charAt(Math.floor(Math.random() * random.length))}`;
                await sleep(20);
            }
            index += 1;
            if (index < titleText.length) {
                setTimeout(animateTitle, 5);
            } else {
                title.textContent = titleText;
            }
        }

        _ = animateTitle();
    </script>
    <script src="lib/glslCanvas.js"></script>
    <script>
        const canvas = document.querySelector(".glslCanvas");
        const sandbox = new GlslCanvas(canvas);

        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            sandbox.setUniform("u_resolution", canvas.width, canvas.height);
        }

        window.addEventListener("resize", resize);
        
        resize();

        let startTime = Date.now();
        let lastTimeShader = performance.now();

        function animate() {

            const now = Date.now();
            const elapsed = (now - startTime) / 1000.0;

            sandbox.setUniform("u_time", elapsed);

            requestAnimationFrame(animate);
        }

        animate(); 
    </script>
    <script>
        let items = {
            "Extended Bio": "../bio/",
            "Projects": "../projects/",
            "Socials": "../@@/",
            "Archive": "../archive/",
            "Statistics": "../stats/",
            "Credit": "../credit/",
            //"Minesweeper?": "../minesweeper/",
            "Hiveborn Digital": "https://hiveborn.digital/"
        };
        let itemImages = {
            "Extended Bio": "blog.png",
            "Projects": "gamedev.png",
            "Socials": "insta.png",
            "Archive": "download.png",
            "Statistics": "stonks.png",
            "Credit": "misc.png",
            //"Minesweeper?": "misc.png",
            "Hiveborn Digital": "hbd.png"
        }
        let itemDescriptions = {
            "Extended Bio": "Self explanatory.",
            "Projects": "My work-in-progress projects. Some may not be available and/or useable as of yet.",
            "Socials": "My social media accounts.",
            "Archive": "Archive of all my old/scrapped work. A lot of it are previous Celeste mods. This is essentially a museum.<br><br>This page is not finished yet.",
            "Statistics": "Basic website statistics.",
            "Credit": "Website credit.",
            //"Minesweeper?": "Minesweeper if it was a roguelike...",
            "Hiveborn Digital": "New Zealand-based indie game dev studio I run."
        }
        let objects = []
        let container = document.getElementById("navigation");
        let descriptionBox = document.getElementById("descriptions");
        let currentItemDescription = "";

        function setup() {
            let index = 0;
            for (let key in items) {
                if (items.hasOwnProperty(key)) {
                    let div = document.createElement("div");
                    let img = document.createElement("div");
                    div.className = "nav-item";
                    img.className = "nav-image";

                    div.addEventListener("mouseover", function(event) {
                        if (currentItemDescription != itemDescriptions[key]){
                            displayItemDescription = `<h3>${key}</h3>${itemDescriptions[key]}`;
                            currentItemDescription = itemDescriptions[key];
                            dindex = 0;
                            descriptionBox.innerHTML = "";
                        }
                    });

                    let p = document.createElement("p");
                    let a = document.createElement("a");
                    let icon = document.createElement("img");
                    icon.src = `../socialicons/${itemImages[key]}`;
                    icon.width = 100;
                    //icon.className = "nav-icon";
                    p.textContent = key;

                    if (items[key] === "https://hiveborn.digital/"){
                        a.location = items[key];

                        a.addEventListener("click", function(event) {
                            event.preventDefault();
                            window.open(this.location, "_top", "noreferrer");
                        });
                    } else {
                        a.href = items[key];
                    }
                    a.className = "nav-link";

                    img.appendChild(icon);
                    a.appendChild(img);
                    a.appendChild(p);
                    div.appendChild(a);

                    container.appendChild(div);

                    objects[index] = div;
                    index += 1;
                }
            }
        }
        let lastTime = 0;
        let spacing = 0;
        let targetSpacing = 0;
        let radius = 500;
        let rotation = 0;
        let speed = 0;
        let scale = 1;
        let minRadius = 200;

        function sleep(ms) {
            return new Promise(resolve => setTimeout(resolve, ms));
        }

        function lerp(start, end, time) {
            return start + (end - start) * time;
        }

        let ringStartTime = Date.now();

        function loop(timestamp) {
            if (document.documentElement.clientHeight < 950 && document.documentElement.clientHeight < document.documentElement.clientWidth){
                if (document.documentElement.clientHeight < 700){
                    scale = 0.55;
                    document.documentElement.style.setProperty("--iconScale", "0.67");
                    document.documentElement.style.setProperty("--iconRingScale", "0.67");
                    document.documentElement.style.setProperty("--navitemScaling", "0.67");
                    minRadius = 190;
                } else {
                    scale = 0.7;
                    document.documentElement.style.setProperty("--iconScale", "0.83");
                    document.documentElement.style.setProperty("--iconRingScale", "0.83");
                    document.documentElement.style.setProperty("--navitemScaling", "0.9");
                    minRadius = 230;
                }
            } else {
                scale = 1;
                document.documentElement.style.setProperty("--iconScale", "1.0");
                document.documentElement.style.setProperty("--iconRingScale", "1.0");
                document.documentElement.style.setProperty("--navitemScaling", "1.3");
                minRadius = 200;
                if (document.documentElement.clientHeight > document.documentElement.clientWidth){
                    minRadius = 300;
                }
            }
            let deltaTime = (timestamp - lastTime) / 1000;
            lastTime = timestamp;

            if (deltaTime > 0.2) {
                deltaTime = 0.2;
            }

            let elapsed = (Date.now() - ringStartTime) / 1000;
            document.documentElement.style.setProperty("--iconRingAngle", `${-18 + (Math.sin(elapsed / 12) * 13)}deg`);
            
            spacing = lerp(spacing, targetSpacing, deltaTime * speed);

            speed += deltaTime * 2;
            if (speed > 4){
                speed = 4;
            }

            rotation += deltaTime / 9;

            radius = (window.innerWidth / 5.5) * scale;
            if (radius < minRadius) {
                radius = minRadius;
            }

            let centerX = document.documentElement.clientWidth / 2;
            let centerY = document.documentElement.clientHeight / 2;

            for (let i = 0; i < objects.length; i++) {
                let angle = (spacing * i) + rotation;

                let x = centerX + radius * Math.cos(angle) - objects[i].offsetWidth / 2;
                let y = centerY + radius * Math.sin(angle) - objects[i].offsetHeight / 2;

                objects[i].style.left = `${x}px`;
                objects[i].style.top = `${y}px`;
                objects[i].style.transform = `scale(${scale})`;
            }

            requestAnimationFrame(loop);
        }
        
        async function start() {
            await sleep(300);
            setup();
            targetSpacing = (2 * Math.PI) / objects.length;
            requestAnimationFrame(loop);
        }
        start();
    </script>
