            <img src="icon.png" width="250px"></img>
            <img src="ringFront.png" width="420px" class="ringSegment"></img>
        </div>
        <div id="schmove">
            <canvas class="glslCanvas"
                data-fragment-url="../shaders/bg.frag"
                data-vertex-url="../shaders/bg.vert">
            </canvas>

            <div class="gradient-overlay"></div>

