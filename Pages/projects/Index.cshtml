@page
@model IndexModel
@{
    ViewData["Title"] = "Daxcr | Projects";
}

<html>
    <head>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Varela&display=swap" rel="stylesheet">
        <meta name="viewport" content="width=device-width, initial-scale=0.5">
        <link rel="stylesheet" href="../css/site.css"/>
    </head>
    <body>
        <div id="title"></div>
        <div class="centerButton">
            <div class="nav-item">
                <a href="../home" class="nav-link">
                    <div class="nav-image">
                        <img src="../socialicons/r.png" width="100">
                    </div>
                    <p>RETURN</p>
                </a>
            </div>
        </div>
        <div id="schmove">
            <canvas class="glslCanvas"
                data-fragment-url="../shaders/bg.frag"
                data-vertex-url="../shaders/bg.vert">
            </canvas>

            <div class="gradient-overlay"></div>

            <div id="navigation"></div>
        </div>

        <div id="descriptions"></div>
    </body>
    <script>
        if (window.self === window.top) {
            window.location.replace("/?path=" + window.location.pathname);
        }
    </script>
    <script>
        document.addEventListener("click", e => {
            const link = e.target.closest("a");
            if (!link) return;

            const audio = new Audio("../audio/click.wav");
            audio.volume = 0.1;
            audio.play();

            e.preventDefault();
            document.getElementById("schmove").classList.add("fade-out");
            document.getElementsByClassName("centerButton")[0].classList.add("fade-out");
            setTimeout(() => {
                window.location = link.href;
                }, 2000);
            });
            window.addEventListener("pageshow", event => {
            document.getElementById("schmove").classList.remove("fade-out");
            document.getElementsByClassName("centerButton")[0].classList.remove("fade-out");
        });
    </script>
    <script>
        displayItemDescription = "";
        const description = document.getElementById("descriptions");
        let dindex = 0;

        async function animateDescription() {
            if (displayItemDescription != description.innerHTML){
                description.style.height = "30%";
                description.style.padding = "1%";
                description.style.outline = "2px var(--quoteOutline) solid";
                for (let i = 0; i < 2; i++) {
                    description.innerHTML = `${displayItemDescription.substring(0, dindex)}${random.charAt(Math.floor(Math.random() * random.length))}`;
                    await sleep(10);
                    dindex += 1;
                }
            } else {
                dindex = 0;
            }
            if (dindex < displayItemDescription.length) {
                setTimeout(animateDescription, 5);
            } else {
                description.innerHTML = displayItemDescription;
                setTimeout(animateDescription, 500);
            }
        }

        _ = animateDescription();
    </script>
    <script>
        const title = document.getElementById("title");
        let titleText = "Projects";
        let random = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@@#$%^&*()_+-=[]{}|;':,.<>/?`~";
        let index = 0;

        function sleep(ms) {
            return new Promise(resolve => setTimeout(resolve, ms));
        }

        async function animateTitle() {
            for (let i = 0; i < 2; i++) {
                title.textContent = `${titleText.substring(0, index)}${random.charAt(Math.floor(Math.random() * random.length))}`;
                await sleep(20);
            }
            index += 1;
            if (index < titleText.length) {
                setTimeout(animateTitle, 5);
            } else {
                title.textContent = titleText;
            }
        }

        _ = animateTitle();
    </script>
    <script src="../lib/glslCanvas.js"></script>
    <script>
        const canvas = document.querySelector(".glslCanvas");
        const sandbox = new GlslCanvas(canvas);

        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            sandbox.setUniform("u_resolution", canvas.width, canvas.height);
        }

        window.addEventListener("resize", resize);
        
        resize();

        let startTime = Date.now();
        let lastTimeShader = performance.now();

        function animate() {

            const now = Date.now();
            const elapsed = (now - startTime) / 1000.0;

            sandbox.setUniform("u_time", elapsed);

            requestAnimationFrame(animate);
        }

        animate();
    </script>
    <script>
        let items = {
            "Honeycomb": "https://github.com/Hiveborn-Digital/Honeycomb",
            "Celeste Mods": "https://gamebanana.com/members/2729693",
            "Weaponry API": "https://github.com/Daxcr/WeaponryAPI",
            "ULTRAHOOK": "https://github.com/Daxcr/ULTRAHOOk",
            "This Website :D": "https://github.com/Daxcr/Website"
        };
        let itemImages = {
            "Honeycomb": "honeycomb.png",
            "Celeste Mods": "celeste.png",
            "ULTRAHOOK": "v1.png",
            "This Website :D": "gamedev.png"
        }
        let itemDescriptions = {
            "Honeycomb": "Honeycomb is a MonoGame-based game engine I'm working on. As of right now, it's not in much of a useable state, however I have a lot planned.<br><br>Honeycomb stores game content in \"packages\", which are separate chunks of game data that can be hot reloaded at will. It's pretty neat.",
            "Celeste Mods": "My GameBanana.",
            "Weaponry API": "Weaponry API is a Celeste mod which can centralise weapon/enemy systems in Celeste. So long as helpers/weapon packs are using Weaponry API, all weapons are compatible.",
            "ULTRAHOOK": "Work-in-progress ULTRAKILL modding API that brings the ease-of-use of Celeste/Everest modding into ULTRAKILL. As of right now, I've barely done anything related to this project lmao.",
            "This Website :D": "<span style=\"color: #ff0000\">Out of the night that covers me,<br><br>Black as the pit from pole to pole,<br><br>I thank whatever gods may be<br><br>For my unconquerable soul.<br><br>In the fell clutch of circumstance<br><br>I have not winced nor cried aloud.<br><br>Under the bludgeonings of chance<br><br>My head is bloody, but unbowed.<br><br>Beyond this place of wrath and tears<br><br>Looms but the Horror of the shade,<br><br>And yet the menace of the years<br><br>Finds and shall find me unafraid.<br><br>It matters not how strait the gate,<br><br>How charged with punishments the scroll,<br><br>I am the master of my fate,<br><br>I am the captain of my soul.</span><br><br><br> - idk Kai Cenat or something" // this poem is called invictus btw
        }
        let objects = []
        let container = document.getElementById("navigation");
        let icon = document.querySelector(".centerButton .nav-item");
        let descriptionBox = document.getElementById("descriptions");
        let currentItemDescription = "";

        function setup() {
            let index = 0;
            for (let key in items) {
                if (items.hasOwnProperty(key)) {
                    let div = document.createElement("div");
                    let img = document.createElement("div");
                    div.className = "nav-item";
                    img.className = "nav-image";

                    div.addEventListener("mouseover", function(event) {
                        if (currentItemDescription != itemDescriptions[key]){
                            displayItemDescription = `<h3>${key}</h3>${itemDescriptions[key]}`;
                            currentItemDescription = itemDescriptions[key];
                            dindex = 0;
                            descriptionBox.innerHTML = "";
                        }
                    });

                    let p = document.createElement("p");
                    let a = document.createElement("a");
                    let icon = document.createElement("img");
                    icon.src = `../socialicons/${itemImages[key]}`;
                    icon.width = 100;
                    //icon.className = "nav-icon";
                    p.textContent = key;

                    a.location = items[key];

                    a.addEventListener("click", function(event) {
                        event.preventDefault();
                        window.open(this.location, "_top", "noreferrer");
                    });

                    a.className = "nav-link";

                    img.appendChild(icon);
                    a.appendChild(img);
                    a.appendChild(p);
                    div.appendChild(a);

                    container.appendChild(div);

                    objects[index] = div;
                    index += 1;
                }
            }
        }
        let lastTime = 0;
        let spacing = 0;
        let targetSpacing = 0;
        let radius = 500;
        let rotation = 0;
        let speed = 0;
        let scale = 1;
        let minRadius = 200;

        function sleep(ms) {
            return new Promise(resolve => setTimeout(resolve, ms));
        }

        function lerp(start, end, time) {
            return start + (end - start) * time;
        }

        function loop(timestamp) {
            if (document.documentElement.clientHeight < 1000 && document.documentElement.clientHeight < document.documentElement.clientWidth){
                if (document.documentElement.clientHeight < 700){
                    scale = 0.55;
                    document.documentElement.style.setProperty("--iconScale", "0.55");
                    minRadius = 190;
                } else {
                    scale = 0.7;
                    document.documentElement.style.setProperty("--iconScale", "0.7");
                    minRadius = 230;
                }
            } else {
                scale = 1;
                document.documentElement.style.setProperty("--iconScale", "1.0");
                minRadius = 200;
                if (document.documentElement.clientHeight > document.documentElement.clientWidth){
                    minRadius = 300;
                }
            }
            let deltaTime = (timestamp - lastTime) / 1000;
            lastTime = timestamp;

            if (deltaTime > 0.2) {
                deltaTime = 0.2;
            }
            
            spacing = lerp(spacing, targetSpacing, deltaTime * speed);

            speed += deltaTime * 2;
            if (speed > 4){
                speed = 4;
            }

            rotation += deltaTime / 9;

            radius = (window.innerWidth / 5.5) * scale;
            if (radius < minRadius) {
                radius = minRadius;
            }

            let centerX = document.documentElement.clientWidth / 2;
            let centerY = document.documentElement.clientHeight / 2;

            for (let i = 0; i < objects.length; i++) {
                let angle = (spacing * i) + rotation;

                let x = centerX + radius * Math.cos(angle) - objects[i].offsetWidth / 2;
                let y = centerY + radius * Math.sin(angle) - objects[i].offsetHeight / 2;

                objects[i].style.left = `${x}px`;
                objects[i].style.top = `${y}px`;
                objects[i].style.transform = `scale(${scale})`;
            }

            requestAnimationFrame(loop);
        }
        
        async function start() {
            await sleep(300);
            setup();
            targetSpacing = (2 * Math.PI) / objects.length;
            requestAnimationFrame(loop);
        }
        start();
    </script>
    <script src="../themeSwapper.js"></script>
    <script>
        window.addEventListener("message", function(event) {
            if (event.data?.type === "theme") {
                for (const [key, val] of Object.entries(event.data.theme)) {
                    document.documentElement.style.setProperty(key, val);
                }
            }
        });
    </script>
</html>