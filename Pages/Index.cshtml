@page
@model Website.Pages.IndexModel
<!DOCTYPE html>
<html>
<head>
    <title>Daxcr</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Varela&display=swap" rel="stylesheet">
    <meta name="viewport" content="width=device-width, initial-scale=0.5">
    <link rel="stylesheet" href="~/css/site.css"/>
    <style>
        body {
            background-color: #000000 !important;
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        iframe {
            width: 100vw;
            height: 100vh;
            border: none;
            display: block;
        }
        .settings {
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.15s ease;
        }
        .chat {
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.15s ease;
        }
        body.chat-open .chat {
            pointer-events: all;
            opacity: 1;
        }
        body.settings-open .settings {
            pointer-events: all;
            opacity: 1;
        }
        #frameContainer {
            filter: blur(0);
            transform: scale(1);
            pointer-events: all;
            transition: filter 0.4s ease, transform 0.4s ease;
        }
        body.settings-open #frameContainer {
            filter: blur(10px);
            transform: scale(0.95);
            pointer-events: none;
        }
        #settingsButton {
            z-index: 99999;
            position: fixed;
            right: 40px;
            top: 40px;
            filter: drop-shadow(0 0 20px #000000);
            transition: transform 0.75s ease, opacity 0.15s ease;
            opacity: 0.6;
        }
        #chatButton {
            z-index: 99999;
            position: fixed;
            right: 40px;
            bottom: 40px;
            filter: drop-shadow(0 0 20px #000000);
            transition: transform 0.75s ease, opacity 0.15s ease;
            opacity: 0.6;
        }
        #chatButton:hover {
            transform: scale(1.2);
        }
        #settingsButton:hover {
            transform: scale(1.2) rotate(90deg);
        }
        body.settings-open #settingsButton{
            opacity: 1;
        }
        #sendButton {
            color: #ffffff;
            font-size: 24px;
            padding: 4px;
            width: 42px;
            height: 42px;
            background-color: #2e2e2eaa;
            border-radius: 10px;
            outline: #8d8d8d 2px solid;
            margin-left: 330px;
            margin-top: -42px;
            text-align: center;
            user-select: none;
            transition: all 0.3s ease;
        }
        #sendButton:hover {
            transform: scale(1.15);
            background-color: #48f556;
        }
        .chatMessage {
            padding: 12px;
            background-color: #1c1c1c6a;
            border-radius: 10px;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>
    <div style="z-index: 99990;" class="settings">
        <label for="themeSwitcher">Theme</label>
        <select id="themeSwitcher" name="themeSwitcher">
            <option value="dark">Dark</option>
            <option value="light">Light</option>
            <option value="midnight">Midnight</option>
            <option value="ultradark">Ultradark</option>
            <option value="seaside">Seaside</option>
            <option value="gilded">Gilded</option>
            <option value="simulation">Simulation</option>
            <option value="simulation-dark">Simulation Dark</option>
            <option value="ocean">Ocean</option>
            <option value="ember">Ember</option>
            <option value="soft">Soft</option>
            <option value="bloodmoon">Blood Moon</option>
            <option value="gloop">Gloop</option>
            <option value="highcontrast">High Contrast</option>
        </select><br>
        <label for="useSound">Sound Effects (not working yet)</label>
        <input type="checkbox" id="useSound"><br>
        
        <label for="chatUsername">Chat Username</label>
        <input type="text" id="chatUsername"><br>

        <label for="adminPasscode">Admin Passcode</label>
        <input type="password" id="adminPasscode"><br>
    </div>

    <img id="settingsButton" width="60px" src="socialicons/settings.png"/>
    <div id="frameContainer">
        <iframe id="frame" src="/home"></iframe>
        <img id="chatButton" width="60px" src="socialicons/chat.png"/>

        <div style="font-size: 50%;" class="chat">
            <p style="color: #b3b3b3;">Messages are ephemeral.</p>
            <p style="color: #b3b3b3;">You may change your username in settings.</p>
            <div style="height: calc(100% - 180px); overflow-y: auto; margin-top: 30px;" id="chatContent"></div>
            <input type="text" id="chatbox" style="width: calc(100% - 62px); height: 42px; font-size: 24px; margin-top: 30px;">
            <div id="sendButton">➤</div>
        </div>
    </div>

    <script>
        if (window.self !== window.top) {
            window.top.location.replace("/");
        }
    </script>
    <script src="~/themeSwapper.js"></script>
    <script>
        if (window.self !== window.top) {
            window.top.location.href = window.location.href;
        }

        document.getElementById("settingsButton").addEventListener("click", function() {
            document.body.classList.toggle("settings-open");
        });
        document.getElementById("chatButton").addEventListener("click", function() {
            document.body.classList.toggle("chat-open");
        });


    </script> 
    <script>
        const frame = document.getElementById("frame");

        const params = new URLSearchParams(window.location.search);
        let path = params.get("path") || window.location.pathname;
        if (path === "/" || path === "") path = "/home";

        frame.src = (path === "/" || path === "") ? "/home?_iframe=1" : path + (path.includes("?") ? "&" : "?") + "_iframe=1";

        if (params.has("path")) {
            history.replaceState(null, "", path === "/home" ? "/" : path);
        }

        function syncUrl() {
            try {
                const current = frame.contentWindow.location.pathname;
                document.title = frame.contentDocument.title;
                history.replaceState(null, "", current === "/home" ? "/" : current);
            } catch (e) {}
        }

        function syncTheme() {
            try {
                const t = localStorage.getItem("theme") ?? "dark";
                frame.contentWindow?.postMessage({ type: "theme", theme: themes[t] }, "*");
            } catch (e) {}
        }

        frame.addEventListener("load", () => {
            syncUrl();
            syncTheme();
        });

        setInterval(() => {
            syncUrl();
            syncTheme();
        }, 200);
    </script>
</body>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/websocket")
        .withAutomaticReconnect()
        .configureLogging(signalR.LogLevel.Information)
        .build();

    (async () => {
        await connection.start();
    })();
</script>
<script src="~/chatroom.js"></script>
</html>