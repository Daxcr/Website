@page
@model Website.Pages.IndexModel
<!DOCTYPE html>
<html>
<head>
    <title>Daxcr</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Varela&display=swap" rel="stylesheet">
    <meta name="viewport" content="width=device-width, initial-scale=0.5">
    <link rel="stylesheet" href="~/css/site.css"/>
    <style>
        body {
            background-color: #000000 !important;
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        iframe {
            width: 100vw;
            height: 100vh;
            border: none;
            display: block;
        }
        .settings {
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.15s ease;
        }
        body.settings-open .settings {
            pointer-events: all;
            opacity: 1;
        }
        #frame {
            filter: blur(0);
            transform: scale(1);
            pointer-events: all;
            transition: filter 0.4s ease, transform 0.4s ease;
        }
        body.settings-open #frame {
            filter: blur(10px);
            transform: scale(0.95);
            pointer-events: none;
        }
        #settingsButton {
            z-index: 99999;
            position: fixed;
            right: 40px;
            top: 40px;
            filter: drop-shadow(0 0 20px #000000);
            transition: transform 0.75s ease, opacity 0.15s ease;
            opacity: 0.6;
        }
        #settingsButton:hover {
            transform: scale(1.2) rotate(90deg);
        }
        body.settings-open #settingsButton{
            opacity: 1;
        }
    </style>
</head>
<body>
    <div style="z-index: 99990;" class="settings">
        <label for="themeSwitcher">Theme</label>
        <select id="themeSwitcher" name="themeSwitcher">
            <option value="dark">Dark</option>
            <option value="light">Light</option>
            <option value="midnight">Midnight</option>
            <option value="seaside">Seaside</option>
            <option value="gilded">Gilded</option>
            <option value="simulation">Simulation</option>
            <option value="simulation-dark">Simulation Dark</option>
            <option value="ocean">Ocean</option>
            <option value="ember">Ember</option>
            <option value="soft">Soft</option>
            <option value="highcontrast">High Contrast</option>
        </select><br><br>
        <input type="checkbox" id="useSound">
        <label for="useSound">Sound Effects (button not working yet)</label>
    </div>
    <img id="settingsButton" width="60px" src="socialicons/settings.png"/>
    <iframe id="frame" src="/home"></iframe>
    <script>
        if (window.self !== window.top) {
            window.top.location.replace("/");
        }
    </script>
    <script src="~/themeSwapper.js"></script>
    <script>
        if (window.self !== window.top) {
            window.top.location.href = window.location.href;
        }

        document.getElementById("settingsButton").addEventListener("click", function() {
            document.body.classList.toggle("settings-open");
        });
    </script> 
    <script>
        const frame = document.getElementById("frame");

        const params = new URLSearchParams(window.location.search);
        let path = params.get("path") || window.location.pathname;
        if (path === "/" || path === "") path = "/home";

        frame.src = (path === "/" || path === "") ? "/home?_iframe=1" : path + (path.includes("?") ? "&" : "?") + "_iframe=1";

        if (params.has("path")) {
            history.replaceState(null, "", path === "/home" ? "/" : path);
        }

        function syncUrl() {
            try {
                const current = frame.contentWindow.location.pathname;
                document.title = frame.contentDocument.title;
                history.replaceState(null, "", current === "/home" ? "/" : current);
            } catch (e) {}
        }

        function syncTheme() {
            try {
                const t = localStorage.getItem("theme") ?? "dark";
                frame.contentWindow?.postMessage({ type: "theme", theme: themes[t] }, "*");
            } catch (e) {}
        }

        frame.addEventListener("load", () => {
            syncUrl();
            syncTheme();
        });

        setInterval(() => {
            syncUrl();
            syncTheme();
        }, 200);
    </script>
</body>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/websocket")
        .withAutomaticReconnect()
        .configureLogging(signalR.LogLevel.Information)
        .build();

    connection.on("ReceiveMessage", (user, message) => {
        console.log(`${user}: ${message}`);
    });

    (async () => {
        await connection.start();
    })();
</script>
</html>